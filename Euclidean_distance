declare @a float
declare @b float
declare @c float
declare @d float

set @a=(select min(lat_n ) from station )
set @b=(select max(lat_n) from station)
set @c=(select min(long_w) from station)
set @d=(select max(long_w) from station)

select cast(sqrt((@a-@b)*(@a-@b)+(@c-@d)*(@c-@d)) as decimal(10,4))

