declare @n float 
set @n=(
select ceiling((cast(count(lat_n) as float)/2)) from station )

select cast(round(lat_n,4) as decimal(10,4)) from (
select lat_n, row_number() over(order by lat_n) [num] from station ) as D where num =@n 
